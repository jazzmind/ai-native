# Busibox AI Advisory App - Environment Variables
# Copy to .env.local and fill in the values

# App Identity
APP_NAME=ai-native
PORT=3018

# Busibox Portal URL (for SSO and navigation)
NEXT_PUBLIC_BUSIBOX_PORTAL_URL=http://localhost:3000
NEXT_PUBLIC_BASE_PATH=/ai-native
NEXT_PUBLIC_PORTAL_BASE_PATH=/portal

# Authentication (Busibox SSO)
AUTHZ_BASE_URL=http://localhost:8010

# Busibox Services
DATA_API_URL=http://localhost:8002
AGENT_API_URL=http://localhost:8000
SEARCH_API_URL=http://localhost:8003

# Local development without Portal SSO
# TEST_SESSION_JWT=your-dev-jwt-here

# Optional debug
# NEXT_PUBLIC_DEBUG=true
# VERBOSE_AUTHZ_LOGGING=false
