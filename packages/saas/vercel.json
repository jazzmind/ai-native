{
  "installCommand": "npm install -g pnpm@9 && cd ../.. && pnpm install --no-frozen-lockfile",
  "buildCommand": "pnpm build",
  "crons": [
    {
      "path": "/api/cron/process-bids",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/heartbeat",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ea-tasks",
      "schedule": "*/30 * * * *"
    }
  ]
}
