{
  "installCommand": "corepack enable && cd ../.. && corepack pnpm install --no-frozen-lockfile",
  "buildCommand": "corepack pnpm build:deploy",
  "crons": [
    {
      "path": "/api/cron/process-bids",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/heartbeat",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/ea-tasks",
      "schedule": "*/30 * * * *"
    }
  ]
}
