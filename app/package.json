{
  "name": "coach-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"next dev --turbopack\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:pack": "next build && electron-builder --dir",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@auth/core": "^0.41.0",
    "@neondatabase/serverless": "^1.0.2",
    "@stripe/stripe-js": "^9.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "better-sqlite3": "^12.8.0",
    "docx": "^9.6.1",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "mammoth": "^1.12.0",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "pdf-parse": "^2.4.5",
    "posthog-js": "^1.367.0",
    "posthog-node": "^5.29.2",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "resend": "^6.10.0",
    "stripe": "^22.0.1",
    "uuid": "^13.0.0"
  },
  "overrides": {
    "micromatch": ">=4.0.8",
    "braces": ">=3.0.3",
    "semver": ">=7.5.2",
    "tough-cookie": ">=4.1.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "drizzle-kit": "^0.31.10",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.1.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.3"
  }
}
