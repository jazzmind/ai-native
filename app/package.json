{
  "name": "coach-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "electron:dev": "concurrently \"next dev --turbopack\" \"wait-on http://localhost:3000 && electron .\"",
    "electron:build": "next build && electron-builder",
    "electron:pack": "next build && electron-builder --dir"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@auth/core": "^0.41.0",
    "better-sqlite3": "^12.8.0",
    "lucide-react": "^1.8.0",
    "next": "^16.2.3",
    "next-auth": "^5.0.0-beta.30",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "uuid": "^13.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^11.0.0",
    "concurrently": "^9.1.2",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4",
    "wait-on": "^8.0.3"
  }
}
